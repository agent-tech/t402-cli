{
  "name": "@agentpay/tpay-cli",
  "version": "0.0.1",
  "description": "T402 CLI for agent automation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tpay": "dist/index.js"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target node --outfile dist/index.js",
    "build:binary": "bun build --compile src/index.ts --outfile tpay",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "author": "TianyiLi",
  "license": "ISC",
  "private": true,
  "dependencies": {
    "commander": "^12.1.0",
    "@solana/keys": "^6.4.0",
    "@solana/web3.js": "^1.98.0",
    "@tetherto/wdk-wallet-solana": "1.0.0-beta.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest",
    "typescript": "^5"
  }
}
